{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "cli_args": {
          "type": "string"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "imageCredentials": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "registry": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "existsSecrets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": {
          "type": "boolean"
        }
      }
    },
    "podSecurityContext": {
      "type": "object"
    },
    "containerSecurityContext": {
      "type": "object"
    },
    "securityContext": {
      "type": "object"
    },
    "operator": {
      "type": "object",
      "properties": {
        "logLevel": {
          "type": "string"
        },
        "supportedNamespacesRegex": {
          "type": "string"
        },
        "listenAddress": {
          "type": "string"
        },
        "metricsPath": {
          "type": "string"
        },
        "k8sCliQpsLimit": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "k8sCliBurstableLimit": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "concurrency": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "syncInterval": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "extraArgs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "extraEnv": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "rbac": {
            "type": "object",
            "properties": {
              "create": {
                "const": true
              }
            },
            "required": [
              "create"
            ]
          },
          "serviceAccount": {
            "type": "object",
            "properties": {
              "create": {
                "const": false
              }
            },
            "required": [
              "create"
            ]
          }
        },
        "required": [
          "rbac",
          "serviceAccount"
        ]
      },
      "then": {
        "properties": {
          "serviceAccount": {
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "imageCredentials": {
            "type": "object",
            "properties": {
              "create": {
                "const": true
              }
            },
            "required": [
              "create"
            ]
          }
        },
        "required": [
          "imageCredentials"
        ]
      },
      "then": {
        "properties": {
          "imageCredentials": {
            "anyOf": [
              {
                "properties": {
                  "existsSecrets": {
                    "type": "array",
                    "minItems": 1
                  }
                },
                "required": [
                  "existsSecrets"
                ]
              },
              {
                "required": [
                  "registry",
                  "username",
                  "password",
                  "email"
                ],
                "properties": {
                  "registry": {
                    "type": "string",
                    "minLength": 1
                  },
                  "username": {
                    "type": "string",
                    "minLength": 1
                  },
                  "password": {
                    "type": "string",
                    "minLength": 1
                  },
                  "email": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
